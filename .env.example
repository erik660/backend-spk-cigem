# Example environment variables for deployment
# Rename to .env or set these in your hosting provider's dashboard

SECRET_KEY=change-me-to-a-secret
DEBUG=False
HUGGINGFACE_API_KEY=your_huggingface_token_here
HF_MODEL_URL=https://api-inference.huggingface.co/models/google/flan-t5-base
HF_TEMPERATURE=0.8
HF_TOP_K=50
HF_TOP_P=0.95
HF_REP_PEN=1.1

# Database (optional - if using SQLite set DEV_SQLITE=1)
DEV_SQLITE=1
MYSQL_DATABASE=
MYSQLUSER=
MYSQLPASSWORD=
MYSQLHOST=
MYSQLPORT=3306
